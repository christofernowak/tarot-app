# Frontend — variáveis de ambiente
# Copie para .env.local (nunca commite .env.local)
#
# ATENÇÃO: variáveis com prefixo VITE_ ficam PÚBLICAS no bundle JS.
# NUNCA coloque chaves privadas aqui (ANTHROPIC_API_KEY, STRIPE_SECRET_KEY, etc.)
# Essas chaves vivem APENAS no .env do backend.

# URL da API backend (só em produção; em dev o proxy do Vite cuida disso)
VITE_API_URL=https://api.meutarot.com.br
